{
  "name": "skillwiki-monorepo",
  "private": true,
  "version": "0.9.42",
  "workspaces": [
    "packages/shared",
    "packages/cli",
    "packages/skills",
    "packages/agent-memory-trends",
    "packages/skillwiki-maintenance"
  ],
  "scripts": {
    "build": "npm run -ws --if-present build",
    "test": "npm run -ws --if-present test",
    "lint": "npm run -ws --if-present lint",
    "bump": "bash scripts/bump-version.sh",
    "release": "bash scripts/release.sh",
    "materialize:plugins": "bash scripts/materialize-plugin-assets.sh",
    "materialize:plugins:check": "bash scripts/materialize-plugin-assets.sh --check",
    "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0"
  }
}
