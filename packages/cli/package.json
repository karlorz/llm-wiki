{
  "name": "skillwiki",
  "version": "0.2.1-beta.10",
  "type": "module",
  "bin": {
    "skillwiki": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && rm -rf ./skills && cp -r ../skills ./skills",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@skillwiki/shared": "*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/karlorz/llm-wiki.git"
  },
  "engines": {
    "node": ">=20"
  }
}
