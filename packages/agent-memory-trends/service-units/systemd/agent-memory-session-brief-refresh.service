[Unit]
Description=SkillWiki agent memory session brief refresh
Documentation=file:/home/agent-memory/llm-wiki/packages/agent-memory-trends/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=agent-memory
Group=agent-memory
WorkingDirectory=/home/agent-memory/llm-wiki
Environment=HOME=/home/agent-memory
Environment=SKILLWIKI_MAINTENANCE_MODE=session-brief-refresh
EnvironmentFile=/home/agent-memory/.config/agent-memory-trends/env
ExecStart=/home/agent-memory/.local/bin/agent-memory-trends-daily
RuntimeMaxSec=900
Nice=10
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
