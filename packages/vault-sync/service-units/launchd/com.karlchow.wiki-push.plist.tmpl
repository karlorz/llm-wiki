<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- TEMPLATE — placeholders replaced by vault-sync-install:
     @SCRIPT_DIR@      → $HOME/.local/share/vault-sync/bin
     @LOG_DIR@         → $HOME/Library/Logs
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.karlchow.wiki-push</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>@SCRIPT_DIR@/wiki-push.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>@LOG_DIR@/wiki-push.log</string>
    <key>StandardErrorPath</key>
    <string>@LOG_DIR@/wiki-push.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/karlchow</string>
    </dict>
</dict>
</plist>
